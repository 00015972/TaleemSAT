# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force these to always be LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env*  text eol=lf
*.sh    text eol=lf

# Binary files — never diff or convert
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
